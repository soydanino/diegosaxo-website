---
const year = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest border-t border-outline-variant/20">
  <div class="flex flex-col md:flex-row justify-between items-center gap-base px-margin-mobile md:px-margin-desktop max-w-7xl mx-auto py-section-gap-mobile md:py-section-gap-desktop">
    <div class="flex flex-col gap-4 items-center md:items-start">
      <div class="font-display-lg text-headline-md text-primary">DIEGO HERRERA</div>
      <div class="flex gap-6 mt-2">
        <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">
          <span class="material-symbols-outlined">radio</span>
        </a>
        <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">
          <span class="material-symbols-outlined">share</span>
        </a>
        <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">
          <span class="material-symbols-outlined">mail</span>
        </a>
      </div>
    </div>

    <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 font-label-md text-label-md">
      <a class="text-on-surface-variant hover:text-secondary transition-colors" href="#music">Music</a>
      <a class="text-on-surface-variant hover:text-secondary transition-colors" href="#tours">Tours</a>
      <a class="text-on-surface-variant hover:text-secondary transition-colors" href="#about">About</a>
      <a class="text-on-surface-variant hover:text-secondary transition-colors" href="#">Privacy</a>
      <a class="text-on-surface-variant hover:text-secondary transition-colors" href="#">Contact</a>
    </div>

    <div class="font-label-md text-label-md text-on-surface-variant text-center md:text-right mt-8 md:mt-0">
      &copy; {year} DIEGO HERRERA. ALL RIGHTS RESERVED.
    </div>
  </div>
</footer>
