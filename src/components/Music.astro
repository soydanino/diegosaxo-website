    <div class="relative min-h-[320px] md:min-h-[440px] overflow-hidden bg-surface-container-high order-1 md:order-2">
      <img
        src="/news/inmigrante-brillar-musica.webp"
        alt="Diego Herrera featured by La República"
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent"></div>
    </div>
  </a>
  </div>
  </div>

  <div class="flex items-center justify-between gap-5 mt-6">
    <div class="flex items-center gap-4 min-w-0">
      <span class="font-label-md text-[11px] text-on-surface-variant tracking-widest whitespace-nowrap">
        <span data-news-current class="text-primary">01</span> / 02
      </span>
      <div data-news-dots class="flex items-center gap-2" aria-label="News carousel navigation">
        <button type="button" data-news-dot="0" class="h-1 w-8 rounded-full bg-primary transition-all" aria-label="News 1"></button>
        <button type="button" data-news-dot="1" class="h-1 w-3 rounded-full bg-white/25 transition-all" aria-label="News 2"></button>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <button type="button" data-news-prev aria-label="Previous news" class="w-10 h-10 rounded-[6px] border border-outline-variant/50 text-on-surface-variant hover:text-primary hover:border-primary/60 transition-colors flex items-center justify-center">
        <span class="material-symbols-outlined text-[20px]">arrow_back</span>
      </button>
      <button type="button" data-news-next aria-label="Next news" class="w-10 h-10 rounded-[6px] border border-outline-variant/50 text-on-surface-variant hover:text-primary hover:border-primary/60 transition-colors flex items-center justify-center">
        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
      </button>
    </div>
  </div>
</section>

<script>
  const newsCarousel = document.querySelector<HTMLElement>('[data-news-carousel]');
  const newsTrack = document.querySelector<HTMLElement>('[data-news-track]');
  const newsSlides = newsTrack ? Array.from(newsTrack.querySelectorAll<HTMLElement>('a')) : [];
  const newsDots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-news-dot]'));
  const newsCurrent = document.querySelector<HTMLElement>('[data-news-current]');
  const newsPrevious = document.querySelector<HTMLButtonElement>('[data-news-prev]');
  const newsNext = document.querySelector<HTMLButtonElement>('[data-news-next]');
  const reduceNewsMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let currentNews = 0;
  let newsAutoplay: ReturnType<typeof setInterval>;

  const showNews = (index: number) => {
    if (!newsTrack || newsSlides.length === 0) return;
    currentNews = (index + newsSlides.length) % newsSlides.length;
    newsTrack.style.transform = `translateX(-${currentNews * 100}%)`;
    if (newsCurrent) newsCurrent.textContent = String(currentNews + 1).padStart(2, '0');

    newsDots.forEach((dot, dotIndex) => {
      const active = dotIndex === currentNews;
      dot.classList.toggle('w-8', active);
      dot.classList.toggle('bg-primary', active);
      dot.classList.toggle('w-3', !active);
      dot.classList.toggle('bg-white/25', !active);
    });
  };

  const stopNewsAutoplay = () => window.clearInterval(newsAutoplay);
  const startNewsAutoplay = () => {
    if (reduceNewsMotion || newsSlides.length < 2) return;
    stopNewsAutoplay();
    newsAutoplay = window.setInterval(() => showNews(currentNews + 1), 6000);
  };

  newsDots.forEach((dot) => {
    dot.addEventListener('click', () => {
      showNews(Number(dot.dataset.newsDot));
      startNewsAutoplay();
    });
  });

  newsPrevious?.addEventListener('click', () => {
    showNews(currentNews - 1);
    startNewsAutoplay();
  });

  newsNext?.addEventListener('click', () => {
    showNews(currentNews + 1);
    startNewsAutoplay();
  });

  let newsTouchStart = 0;
  newsCarousel?.addEventListener('touchstart', (event) => {
    newsTouchStart = event.touches[0].clientX;
    stopNewsAutoplay();
  }, { passive: true });

  newsCarousel?.addEventListener('touchend', (event) => {
    const distance = newsTouchStart - event.changedTouches[0].clientX;
    if (Math.abs(distance) > 40) showNews(currentNews + (distance > 0 ? 1 : -1));
    startNewsAutoplay();
  }, { passive: true });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopNewsAutoplay();
    else startNewsAutoplay();
  });

  showNews(0);
  startNewsAutoplay();
</script>
