        src="/news/20250904_DiegoHerrera_KellyDavidson_0273.jpg"
        alt="Diego Herrera at Berklee College of Music"
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent"></div>
    </div>

    <div class="flex flex-col justify-center p-7 md:p-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary text-[22px]" style="font-variation-settings: 'FILL' 1">school</span>
        <span class="font-label-md text-[11px] text-primary uppercase tracking-[0.2em]">Berklee College of Music · Class of 2026</span>
      </div>
      <h3 class="font-headline-lg text-[30px] md:text-[42px] leading-tight text-on-surface mb-5">
        Berklee Student Ambassador
      </h3>
      <p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed max-w-xl">
        Diego Herrera represents the Berklee student community as a College of Music Student Ambassador.
      </p>
      <span class="mt-8 inline-flex items-center gap-2 font-label-md text-label-md text-primary uppercase tracking-widest">
        View official profile
        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">open_in_new</span>
      </span>
    </div>
  </a>

  <a
    href="https://larepublica.pe/sociedad/2025/01/07/diego-herrera-el-inmigrante-peruano-que-hace-brillar-nuestra-musica-en-ee-uu-tenia-ese-hambre-evat-159082"
    target="_blank"
    rel="noopener noreferrer"
    class="scroll-reveal group grid md:grid-cols-[1.15fr_minmax(280px,0.85fr)] min-w-full overflow-hidden rounded-[10px] bg-surface-container-low border border-outline-variant/30 hover:border-primary/60 shadow-2xl transition-colors duration-300"
  >
    <div class="flex flex-col justify-center p-7 md:p-12 order-2 md:order-1">
      <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary text-[22px]" style="font-variation-settings: 'FILL' 1">newspaper</span>
        <span class="font-label-md text-[11px] text-primary uppercase tracking-[0.2em]">La República · January 7, 2025</span>
      </div>
