---
const events = [
  {
    day: '19',
    month: 'Dic',
    venue: 'Jazz Zone',
    location: 'Lima, PE',
    note: '',
  },
  {
    day: '7',
    month: 'Ene',
    venue: 'Cocodrilo Verde',
    location: 'Lima, PE',
    note: '',
  },
  {
    day: '8',
    month: 'Ene',
    venue: 'Cocodrilo Verde',
    location: 'Lima, PE',
    note: '',
  },
  {
    day: '13',
    month: 'Ene',
    venue: 'La Noche de Barranco',
    location: 'Lima, PE',
    note: '',
  },
];
---

<section class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-lowest" id="tours">
  <div class="px-margin-mobile md:px-margin-desktop max-w-7xl mx-auto">

    <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface tracking-tight mb-2" data-i18n="Proximos Eventos">Proximos Eventos</h2>
        <div class="w-20 h-1 bg-primary"></div>
      </div>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-md" data-i18n="Encuentra a Diego en vivo en los mejores escenarios de Lima.">
        Encuentra a Diego en vivo en los mejores escenarios de Lima.
      </p>
    </div>

    <div class="space-y-0">
      {events.map((event, i) => (
        <div class={`tour-row scroll-reveal flex flex-col md:flex-row items-start md:items-center justify-between py-8 border-b border-white/10 hover:bg-white/[0.03] px-4 transition-all`} style={`animation-delay: ${i * 80}ms`}>
          <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-16 mb-5 md:mb-0">
            <!-- Date -->
            <div class="flex items-baseline gap-2 min-w-[110px]">
              <span class="font-display-lg text-headline-md text-primary leading-none">{event.day}</span>
              <span class="font-label-md text-label-md text-on-surface-variant uppercase tracking-widest">{event.month}</span>
            </div>
            <!-- Venue -->
            <div class="space-y-1">
              <h4 class="font-headline-md text-headline-md text-on-surface">{event.venue}</h4>
              <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-widest">{event.location}</p>
            </div>
          </div>
          <div class="flex items-center gap-6 w-full md:w-auto">
            {event.note && (
              <div class="hidden lg:block font-body-md text-on-surface-variant italic">{event.note}</div>
            )}
            <a
              href={`mailto:contact@diegosaxo.com?subject=Reserva - ${event.venue} ${event.day} ${event.month}`}
              class="w-full md:w-auto text-center border border-primary text-primary px-8 py-3 font-label-md text-label-md uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-all"
            >
              Reservar
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
