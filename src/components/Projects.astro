---
const projects = [
  {
    id: 'H9bLpshSp4k',
    title: 'Luna de Fuego',
    category: 'Video Clip',
    description: 'Jazz Afroperuano',
    thumb: '/thumbnails/fuego-diego-herrera.jpg',
  },
  {
    id: 'Mg1xSKNOvYk',
    title: 'Silent Beach',
    category: 'Live',
    description: 'Live at Berklee',
    thumb: '/thumbnails/silent-beach.jpg',
  },
  {
    id: 'Yo1OvY9nJmo',
    title: 'Lima Tour II',
    category: 'Live',
    description: 'Live at Cocodrilo Verde',
    thumb: '/thumbnails/lima-tour-2.jpg',
  },
  {
    id: '06KJh9r6S6M',
    title: 'Amazing Mirror',
    category: 'Live',
    description: 'Live at La Noche de Barranco',
    thumb: '/thumbnails/amazing-mirror.jpg',
  },
  {
    id: 'BeJTky4FbZ0',
    title: 'Flor Nocturna',
    category: 'Live',
    description: 'Live at Cocodrilo Verde',
    thumb: '/thumbnails/flor-nocturna.jpg',
  },
  {
    id: '_aqSXa1wBSE',
    title: 'Ashia',
    category: 'Studio',
    description: 'Afro-Peruvian Jazz',
    thumb: '/thumbnails/ashia.jpg',
  },
];

const watchUrl = (id: string) => `https://www.youtube.com/watch?v=${id}`;

const badgeClass: Record<string, string> = {
  'Live':       'bg-primary text-on-primary',
  'Studio':     'bg-surface-container-high text-on-surface border border-outline-variant/40',
  'Video Clip': 'bg-[#fd8b00] text-[#2f1500]',
};
---

<section
  class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-lowest font-sans"
  id="projects"
>
  <div class="px-margin-mobile md:px-margin-desktop max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span class="font-label-md text-label-md text-on-surface-variant tracking-widest uppercase">
            Performances & Recordings
          </span>
        </div>
        <h2 class="font-sans text-headline-lg text-on-surface tracking-tight mb-2">Projects</h2>
        <div class="w-20 h-[2px] bg-primary"></div>
      </div>

      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-xs leading-relaxed">
        A selection of performances, recordings and collaborations.
      </p>
    </div>

    <!-- Grid: first card featured (2 cols), rest 3-col -->
    <div data-project-carousel class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 items-start">

      {projects.map((p, i) => (
        <a
          href={watchUrl(p.id)}
          target="_blank"
          rel="noopener noreferrer"
          data-project-card
          data-project-index={i}
          class={`scroll-reveal group relative block overflow-hidden bg-black ring-1 ring-white/5 hover:ring-primary/40 transition-all duration-300 leading-none ${i === 0 ? 'md:col-span-2 lg:col-span-2' : ''}`}
          style={`animation-delay:${i * 80}ms`}
        >
          <!-- Thumbnail -->
          <div class={`relative overflow-hidden aspect-[8/5] ${i === 0 ? 'lg:aspect-[16/5]' : ''}`}>
            <div
              data-project-image
              class="absolute inset-0 group-hover:scale-105 transition-transform duration-700 ease-out"
              style={`background-image: url('${p.thumb}'); background-size: cover; background-position: center top; background-repeat: no-repeat;`}
            />

            <!-- Gradient: always dark at bottom, intensifies on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/25 to-black/10 group-hover:from-black/95 group-hover:via-black/40 transition-all duration-500" />

            <!-- Top row -->
            <div class="absolute top-3 left-3 right-3 flex items-start justify-between">
              <!-- Category badge -->
              <span data-project-category class={`font-label-md text-[10px] uppercase tracking-widest px-2.5 py-1 ${badgeClass[p.category] ?? 'bg-surface-container text-on-surface'}`}>
                {p.category}
              </span>

              <!-- YouTube icon -->
              <svg
                class="w-5 h-5 fill-current text-white/40 group-hover:text-white/80 transition-colors duration-300"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </div>

            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-14 h-14 rounded-full bg-black/45 backdrop-blur-sm border border-white/20 flex items-center justify-center group-hover:scale-110 group-hover:bg-primary/75 group-hover:border-primary/50 transition-all duration-300">
                <span
                  class="material-symbols-outlined text-white text-[26px] ml-0.5"
                  style="font-variation-settings: 'FILL' 1"
                >
                  play_arrow
                </span>
              </div>
            </div>

            <!-- Bottom info -->
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
              <h3 data-project-title class={`font-sans text-white font-semibold leading-tight ${i === 0 ? 'text-[20px]' : 'text-[16px]'}`}>
                {p.title}
              </h3>
              <div class="flex items-center justify-between mt-1.5">
                <p data-project-description class="font-label-md text-[12px] text-white/55 tracking-wide">{p.description}</p>
                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0 transition-all duration-300">
                  <span class="font-label-md text-[11px] text-primary uppercase tracking-widest">Watch</span>
                  <span class="material-symbols-outlined text-primary text-[15px]">arrow_forward</span>
                </div>
              </div>
            </div>
          </div>
        </a>
      ))}

    </div>

  </div>
</section>

<script define:vars={{ projects, badgeClass }}>
  const carousel = document.querySelector('[data-project-carousel]');
  const allCards = Array.from(document.querySelectorAll('[data-project-card]'));
  const cards = allCards.slice(0, 5);
  const desktopQuery = window.matchMedia('(min-width: 768px)');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  let waitingProject = 5;
  let slotToReplace = 0;

  const updateCard = (card, projectIndex) => {
    const project = projects[projectIndex];
    const category = card.querySelector('[data-project-category]');

    card.href = `https://www.youtube.com/watch?v=${project.id}`;
    card.dataset.projectIndex = String(projectIndex);
    card.setAttribute('aria-label', `Watch ${project.title} on YouTube`);
    card.querySelector('[data-project-image]').style.backgroundImage = `url('${project.thumb}')`;
    card.querySelector('[data-project-title]').textContent = project.title;
    card.querySelector('[data-project-description]').textContent = project.description;
    category.textContent = project.category;
    category.className = `font-label-md text-[10px] uppercase tracking-widest px-2.5 py-1 ${badgeClass[project.category] ?? 'bg-surface-container text-on-surface'}`;
  };

  if (desktopQuery.matches && cards.length === 5 && projects.length > 5) {
    const rotation = window.setInterval(() => {
      const card = cards[slotToReplace];
      const outgoingProject = Number(card.dataset.projectIndex);

      card.classList.add('project-card-leaving');

      window.setTimeout(() => {
        updateCard(card, waitingProject);
        waitingProject = outgoingProject;
        slotToReplace = (slotToReplace + 1) % cards.length;
        card.classList.remove('project-card-leaving');
        card.classList.add('project-card-entering');
        window.requestAnimationFrame(() => card.classList.remove('project-card-entering'));
        window.applySiteLanguage?.();
      }, 350);
    }, 5000);

    window.addEventListener('pagehide', () => window.clearInterval(rotation), { once: true });
  }

  if (!desktopQuery.matches && carousel && allCards.length > 1 && !reducedMotion.matches) {
    let activeSlide = 0;
    let autoplay;

    const goToSlide = (index) => {
      activeSlide = (index + allCards.length) % allCards.length;
      const card = allCards[activeSlide];
      carousel.scrollTo({
        left: card.offsetLeft - carousel.offsetLeft,
        behavior: 'smooth',
      });
    };

    const stopAutoplay = () => window.clearInterval(autoplay);
    const startAutoplay = () => {
      stopAutoplay();
      autoplay = window.setInterval(() => goToSlide(activeSlide + 1), 4000);
    };

    let scrollTimer;
    carousel.addEventListener('scroll', () => {
      window.clearTimeout(scrollTimer);
      scrollTimer = window.setTimeout(() => {
        activeSlide = allCards.reduce((closest, card, index) => {
          const currentDistance = Math.abs(card.offsetLeft - carousel.offsetLeft - carousel.scrollLeft);
          const closestDistance = Math.abs(allCards[closest].offsetLeft - carousel.offsetLeft - carousel.scrollLeft);
          return currentDistance < closestDistance ? index : closest;
        }, 0);
      }, 100);
    }, { passive: true });

    carousel.addEventListener('pointerdown', stopAutoplay);
    carousel.addEventListener('pointerup', startAutoplay);
    carousel.addEventListener('pointercancel', startAutoplay);
    window.addEventListener('pagehide', stopAutoplay, { once: true });
    startAutoplay();
  }
</script>

<style>
  [data-project-card] {
    transition: opacity 350ms ease, transform 350ms ease, box-shadow 300ms ease;
  }

  .project-card-leaving,
  .project-card-entering {
    opacity: 0;
    transform: translateY(12px) scale(0.985);
  }

  @media (max-width: 767px) {
    [data-project-carousel] {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      overscroll-behavior-inline: contain;
      scrollbar-width: none;
      padding-inline: 6%;
      margin-inline: -6%;
    }

    [data-project-carousel]::-webkit-scrollbar {
      display: none;
    }

    [data-project-card] {
      flex: 0 0 88%;
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }
  }

  @media (min-width: 768px) {
    [data-project-card]:nth-child(n + 6) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-project-card] {
      transition-duration: 1ms;
    }
  }
</style>
