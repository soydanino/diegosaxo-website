---
// ── Agrega aquí los links de YouTube ─────────────────────────
// Solo necesitas el ID del video (lo que va después de ?v= en la URL)
// Ejemplo: https://www.youtube.com/watch?v=dQw4w9WgXcQ → id: 'dQw4w9WgXcQ'
const projects = [
  {
    id: 'H9bLpshSp4k',
    title: 'Luna de Fuego',
    category: 'Video Clip',
    description: 'Jazz Afroperuano',
  },
  {
    id: 'Mg1xSKNOvYk',
    title: 'Silent Beach',
    category: 'Live',
    description: 'Live at Berklee',
  },
  {
    id: 'Yo1OvY9nJmo',
    title: 'Lima Tour II',
    category: 'Live',
    description: 'Live at Cocodrilo Verde',
  },
  {
    id: '06KJh9r6S6M',
    title: 'Amazing Mirror',
    category: 'Live',
    description: 'Live at La Noche de Barranco',
  },
  {
    id: 'BeJTky4FbZ0',
    title: 'Flor Nocturna',
    category: 'Live',
    description: 'Live at Cocodrilo Verde',
  },
  {
    id: '_aqSXa1wBSE',
    title: 'Ashia',
    category: 'Studio',
    description: 'Afro-Peruvian Jazz',
  },
];

const thumb = (id: string) =>
  `https://img.youtube.com/vi/${id}/maxresdefault.jpg`;
const watchUrl = (id: string) =>
  `https://www.youtube.com/watch?v=${id}`;
---

<section class="py-section-gap-mobile md:py-section-gap-desktop px-margin-mobile md:px-margin-desktop max-w-7xl mx-auto" id="projects">

  <!-- Header -->
  <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
      <h2 class="font-headline-lg text-headline-lg text-on-surface tracking-tight mb-2">Projects</h2>
      <div class="w-20 h-1 bg-primary"></div>
    </div>
    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-md">
      A selection of performances, recordings and collaborations.
    </p>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((p, i) => (
      <a
        href={watchUrl(p.id)}
        target="_blank"
        rel="noopener noreferrer"
        class="scroll-reveal group relative block overflow-hidden bg-surface-container-low"
        style={`animation-delay:${i * 100}ms`}
      >
        <!-- Thumbnail -->
        <div class="relative aspect-video overflow-hidden">
          <img
            src={thumb(p.id)}
            alt={p.title}
            class="w-full h-full object-cover brightness-75 group-hover:brightness-90 group-hover:scale-105 transition-all duration-500"
            loading="lazy"
          />

          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />

          <!-- Category badge -->
          <span class="absolute top-4 left-4 bg-primary text-on-primary font-label-md text-[11px] uppercase tracking-widest px-3 py-1">
            {p.category}
          </span>

          <!-- Play button -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-black/50 border border-white/20 backdrop-blur-sm flex items-center justify-center group-hover:scale-110 group-hover:bg-primary/80 group-hover:border-primary transition-all duration-300">
              <span
                class="material-symbols-outlined text-white text-[30px] ml-1"
                style="font-variation-settings: 'FILL' 1"
              >
                play_arrow
              </span>
            </div>
          </div>

          <!-- YouTube icon bottom right -->
          <div class="absolute bottom-4 right-4 opacity-60 group-hover:opacity-100 transition-opacity">
            <svg class="w-6 h-6 text-white fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
        </div>

        <!-- Card footer -->
        <div class="px-5 py-4 border-t border-outline-variant/20 flex items-center justify-between gap-4">
          <div class="min-w-0">
            <h3 class="font-headline-md text-[16px] text-on-surface truncate group-hover:text-primary transition-colors duration-200">
              {p.title}
            </h3>
            <p class="font-label-md text-label-md text-on-surface-variant mt-0.5 truncate">
              {p.description}
            </p>
          </div>
          <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary group-hover:translate-x-1 transition-all duration-200 shrink-0 text-[20px]">
            arrow_forward
          </span>
        </div>

      </a>
    ))}
  </div>

</section>
