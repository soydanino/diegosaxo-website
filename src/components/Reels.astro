---
const INSTAGRAM_URL = 'https://www.instagram.com/diegosaxo02/';

const reels = [
  {
    url: 'https://www.instagram.com/reel/DWwus7HCYwK/',
    gradient: 'linear-gradient(160deg, #1a0010 0%, #5a0038 45%, #2a0018 100%)',
    accentColor: '#b42c76',
    caption: 'POV: tu novia te pide que vayas loco en su show',
    bars: [40, 70, 55, 85, 45, 90, 60, 75, 50, 80, 65, 35],
  },
  {
    url: 'https://www.instagram.com/reel/Da1QbMiNG5y/',
    gradient: 'linear-gradient(160deg, #0a0012 0%, #3d0050 45%, #150028 100%)',
    accentColor: '#8b3fc0',
    caption: 'Últimos días de secundaria',
    bars: [60, 45, 80, 35, 95, 50, 70, 40, 85, 55, 75, 30],
  },
  {
    url: 'https://www.instagram.com/reel/DaJn_7BNfnR/',
    gradient: 'linear-gradient(160deg, #001018 0%, #004060 45%, #001828 100%)',
    accentColor: '#1a8fc0',
    caption: 'Toque número 56',
    bars: [75, 50, 90, 60, 40, 80, 55, 95, 45, 70, 35, 85],
  },
  {
    url: 'https://www.instagram.com/reel/DZ3Ut_ay4bx/',
    gradient: 'linear-gradient(160deg, #101000 0%, #504000 45%, #281800 100%)',
    accentColor: '#c09020',
    caption: 'Con mis alumnos de saxo',
    bars: [50, 85, 40, 70, 60, 45, 90, 55, 75, 35, 80, 50],
  },
  {
    url: 'https://www.instagram.com/reel/DZYE1WEppEb/',
    gradient: 'linear-gradient(160deg, #0a1200 0%, #304800 45%, #182000 100%)',
    accentColor: '#78b020',
    caption: 'Ahh las dudas',
    bars: [85, 60, 40, 75, 55, 90, 45, 70, 80, 50, 35, 65],
  },
  {
    url: 'https://www.instagram.com/reel/DYc3VJ9pCs5/',
    gradient: 'linear-gradient(160deg, #180008 0%, #680030 45%, #300018 100%)',
    accentColor: '#e05080',
    caption: 'POV: Jacob Collier se aparece en tu graduación',
    bars: [55, 80, 65, 45, 90, 70, 40, 85, 50, 75, 60, 95],
  },
];
---

<section class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-lowest" id="reels">
  <div class="px-margin-mobile md:px-margin-desktop max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <svg class="w-5 h-5 text-primary shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <a
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors tracking-widest uppercase"
          >
            @diegosaxo02
          </a>
        </div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface tracking-tight mb-3">Ultimos Reels</h2>
        <div class="w-20 h-[2px] bg-primary"></div>
      </div>

      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 border border-outline-variant text-on-surface-variant px-6 py-3 rounded-[6px] font-label-md text-label-md uppercase tracking-widest hover:border-primary hover:text-primary transition-all self-end"
      >
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0">open_in_new</span>
        Ver perfil
      </a>
    </div>

    <!-- Desktop grid -->
    <div class="hidden md:grid md:grid-cols-6 gap-4">
      {reels.map((reel, i) => (
        <a
          href={reel.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={reel.caption}
          class="scroll-reveal group relative overflow-hidden cursor-pointer ring-1 ring-white/10 hover:ring-primary/50 transition-all duration-300 hover:-translate-y-1.5"
          style={`animation-delay: ${i * 80}ms`}
        >
          <div class="aspect-[9/16] relative overflow-hidden" style={`background: ${reel.gradient};`}>

            <!-- Animated grain texture -->
            <div class="absolute inset-0 opacity-[0.06]"
              style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.75%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size: 120px;">
            </div>

            <!-- EQ bars background decoration -->
            <div class="absolute bottom-[30%] left-1/2 -translate-x-1/2 flex items-end gap-[3px] opacity-15 group-hover:opacity-25 transition-opacity duration-500">
              {reel.bars.map((h, idx) => (
                <div
                  class="reel-bar w-[3px] rounded-full transition-all duration-300"
                  style={`height: ${h * 0.55}px; background: ${reel.accentColor}; animation-delay: ${idx * 60}ms;`}
                ></div>
              ))}
            </div>

            <!-- Radial glow from bottom -->
            <div
              class="absolute inset-0 opacity-30 group-hover:opacity-50 transition-opacity duration-500"
              style={`background: radial-gradient(ellipse at 50% 100%, ${reel.accentColor}55 0%, transparent 60%)`}
            ></div>

            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div
                class="relative w-14 h-14 rounded-full flex items-center justify-center group-hover:scale-110 transition-all duration-300"
                style={`background: ${reel.accentColor}22; border: 1.5px solid ${reel.accentColor}66; backdrop-filter: blur(4px);`}
              >
                <!-- Pulse ring on hover -->
                <div
                  class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                  style={`box-shadow: 0 0 0 8px ${reel.accentColor}22;`}
                ></div>
                <span
                  class="material-symbols-outlined text-white text-[26px] ml-0.5"
                  style="font-variation-settings: 'FILL' 1"
                >
                  play_arrow
                </span>
              </div>
            </div>

            <!-- Top-right link icon -->
            <div class="absolute top-2.5 right-2.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="bg-black/70 backdrop-blur-sm p-1.5">
                <span class="material-symbols-outlined text-white/80 text-[14px]">open_in_new</span>
              </div>
            </div>

            <!-- Bottom caption -->
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent pt-12 pb-3 px-3">
              <p class="font-label-md text-[11px] text-white/85 leading-tight tracking-wide line-clamp-2">{reel.caption}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile carousel -->
    <div class="md:hidden relative" id="reels-carousel">
      <div class="overflow-hidden -mx-margin-mobile">
        <div
          id="reels-track"
          class="flex transition-transform duration-500 ease-out will-change-transform"
          style="gap: 12px; padding: 0 20px;"
        >
          {reels.map((reel, i) => (
            <a
              href={reel.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={reel.caption}
              class="group relative shrink-0 overflow-hidden ring-1 ring-white/10 cursor-pointer"
              style="width: calc(80vw); max-width: 280px;"
            >
              <div class="aspect-[9/16] relative overflow-hidden" style={`background: ${reel.gradient};`}>

                <!-- Grain -->
                <div class="absolute inset-0 opacity-[0.06]"
                  style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.75%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size: 120px;">
                </div>

                <!-- EQ bars background -->
                <div class="absolute bottom-[30%] left-1/2 -translate-x-1/2 flex items-end gap-[4px] opacity-15">
                  {reel.bars.map((h) => (
                    <div
                      class="w-[4px] rounded-full"
                      style={`height: ${h * 0.75}px; background: ${reel.accentColor};`}
                    ></div>
                  ))}
                </div>

                <!-- Radial glow -->
                <div
                  class="absolute inset-0 opacity-35"
                  style={`background: radial-gradient(ellipse at 50% 100%, ${reel.accentColor}55 0%, transparent 60%)`}
                ></div>

                <!-- Play button -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div
                    class="relative w-16 h-16 rounded-full flex items-center justify-center"
                    style={`background: ${reel.accentColor}28; border: 1.5px solid ${reel.accentColor}70; backdrop-filter: blur(4px);`}
                  >
                    <span
                      class="material-symbols-outlined text-white text-[30px] ml-0.5"
                      style="font-variation-settings: 'FILL' 1"
                    >
                      play_arrow
                    </span>
                  </div>
                </div>

                <!-- Bottom caption -->
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent pt-14 pb-4 px-4">
                  <p class="font-label-md text-[12px] text-white/85 leading-tight tracking-wide line-clamp-2">{reel.caption}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Dot indicators -->
      <div class="flex justify-center gap-2 mt-5" id="reels-dots">
        {reels.map((_, i) => (
          <button
            class={`reel-dot h-[3px] rounded-full transition-all duration-300 ${i === 0 ? 'w-6 bg-primary' : 'w-2 bg-white/25'}`}
            data-index={i}
            aria-label={`Reel ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

    <!-- CTA: mobile solo -->
    <div class="mt-8 flex md:hidden">
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full flex items-center justify-center gap-2 border border-outline-variant text-on-surface-variant px-6 py-3 rounded-[6px] font-label-md text-label-md uppercase tracking-widest hover:border-primary hover:text-primary transition-all"
      >
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0">open_in_new</span>
        Ver perfil en Instagram
      </a>
    </div>

  </div>
</section>

<script>
  (function () {
    const carousel = document.getElementById('reels-carousel');
    if (!carousel) return;
    if (window.innerWidth >= 768) return;

    const track = document.getElementById('reels-track') as HTMLElement;
    const dots = document.querySelectorAll<HTMLElement>('.reel-dot');
    const cards = track.querySelectorAll<HTMLElement>('a');
    const total = cards.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      const card = cards[current];
      const cardWidth = card.offsetWidth + 12;
      track.style.transform = `translateX(-${current * cardWidth}px)`;

      dots.forEach((dot, i) => {
        if (i === current) {
          dot.style.width = '24px';
          dot.style.backgroundColor = '#921F5D';
          dot.style.opacity = '1';
        } else {
          dot.style.width = '8px';
          dot.style.backgroundColor = 'rgba(255,255,255,0.25)';
          dot.style.opacity = '1';
        }
      });
    }

    function startAutoplay() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 3200);
    }

    function stopAutoplay() {
      clearInterval(timer);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.index || '0');
        goTo(index);
        stopAutoplay();
        startAutoplay();
      });
    });

    let touchStartX = 0;
    let touchStartTime = 0;
    let isDragging = false;

    track.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartTime = Date.now();
      isDragging = true;
      stopAutoplay();
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const diff = touchStartX - e.changedTouches[0].clientX;
      const elapsed = Date.now() - touchStartTime;
      if (Math.abs(diff) > 40 || (Math.abs(diff) > 20 && elapsed < 250)) {
        goTo(diff > 0 ? current + 1 : current - 1);
      }
      startAutoplay();
    }, { passive: true });

    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        const diff = Math.abs(touchStartX - (e as MouseEvent).clientX);
        if (diff > 5) e.preventDefault();
      });
    });

    goTo(0);
    startAutoplay();

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });
  })();
</script>

<style>
  #reels-track {
    transform: translateX(0);
  }

  .reel-bar {
    animation: eq-breathe 2s ease-in-out infinite alternate;
  }

  @keyframes eq-breathe {
    0%   { transform: scaleY(0.5); opacity: 0.6; }
    100% { transform: scaleY(1);   opacity: 1; }
  }
</style>
