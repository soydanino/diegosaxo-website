---
const INSTAGRAM_URL = 'https://www.instagram.com/diegosaxo02/';

const reels = [
  {
    gradient: 'from-[#1a1200] via-[#3d2b00] to-[#1a1200]',
    accent: '#f2ca50',
    label: 'En vivo · Blue Note',
    duration: '0:48',
  },
  {
    gradient: 'from-[#0e0e0e] via-[#2a1f00] to-[#0e0e0e]',
    accent: '#d4af37',
    label: 'Improvización nocturna',
    duration: '1:12',
  },
  {
    gradient: 'from-[#130e00] via-[#3a2900] to-[#130e00]',
    accent: '#e9c349',
    label: 'Backstage · Tokio',
    duration: '0:34',
  },
  {
    gradient: 'from-[#0a0a0a] via-[#2e2000] to-[#0a0a0a]',
    accent: '#ffb77d',
    label: 'Session de estudio',
    duration: '0:57',
  },
  {
    gradient: 'from-[#161000] via-[#3c2a00] to-[#161000]',
    accent: '#f2ca50',
    label: 'Concierto · Madrid',
    duration: '1:03',
  },
  {
    gradient: 'from-[#0e0e0e] via-[#271a00] to-[#0e0e0e]',
    accent: '#d4af37',
    label: 'Jazz en las calles',
    duration: '0:41',
  },
];
---

<section class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-lowest" id="reels">
  <div class="px-margin-mobile md:px-margin-desktop max-w-7xl mx-auto">

    {/* Header */}
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <div class="flex items-center gap-3 mb-3">
          {/* Instagram wordmark icon */}
          <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <a
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors tracking-widest uppercase"
          >
            @diegosaxo02
          </a>
        </div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface tracking-tight mb-2">Últimos Reels</h2>
        <div class="w-20 h-1 bg-primary"></div>
      </div>

      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 border border-outline-variant text-on-surface-variant px-6 py-3 font-label-md text-label-md uppercase tracking-widest hover:border-primary hover:text-primary transition-all self-end"
      >
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0">open_in_new</span>
        Ver perfil
      </a>
    </div>

    {/* Reels grid — horizontal scroll on mobile, grid on desktop */}
    <div class="relative">
      {/* Fade edge on desktop right side */}
      <div class="hidden md:block absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-surface-container-lowest to-transparent z-10 pointer-events-none"></div>

      <div class="flex gap-4 overflow-x-auto md:grid md:grid-cols-6 md:overflow-visible pb-4 md:pb-0 snap-x snap-mandatory md:snap-none scrollbar-none -mx-margin-mobile px-margin-mobile md:mx-0 md:px-0">
        {reels.map((reel, i) => (
          <a
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="scroll-reveal group relative shrink-0 w-[52vw] md:w-auto snap-start overflow-hidden cursor-pointer"
            style={`animation-delay: ${i * 80}ms`}
          >
            {/* Card */}
            <div class={`aspect-[9/16] bg-gradient-to-b ${reel.gradient} relative overflow-hidden`}>

              {/* Noise texture overlay */}
              <div class="absolute inset-0 opacity-[0.04]"
                style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size: 150px;">
              </div>

              {/* Accent glow */}
              <div
                class="absolute inset-0 opacity-20 group-hover:opacity-30 transition-opacity duration-500"
                style={`background: radial-gradient(ellipse at 50% 60%, ${reel.accent}55 0%, transparent 70%)`}
              ></div>

              {/* Musical note decorative */}
              <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[64px] opacity-10 select-none pointer-events-none">
                ♪
              </div>

              {/* Play button */}
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-14 h-14 rounded-full bg-black/40 backdrop-blur-sm border border-white/20 flex items-center justify-center group-hover:scale-110 group-hover:bg-black/60 transition-all duration-300">
                  <span
                    class="material-symbols-outlined text-white text-[28px] ml-0.5"
                    style="font-variation-settings: 'FILL' 1"
                  >
                    play_arrow
                  </span>
                </div>
              </div>

              {/* Duration badge */}
              <div class="absolute top-3 right-3 bg-black/60 backdrop-blur-sm px-2 py-0.5 rounded-full">
                <span class="font-label-md text-[11px] text-white/90">{reel.duration}</span>
              </div>

              {/* Bottom gradient + label */}
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent pt-8 pb-3 px-3">
                <p class="font-label-md text-[12px] text-white/90 leading-tight">{reel.label}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    {/* Mobile CTA */}
    <div class="mt-8 flex md:hidden">
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full flex items-center justify-center gap-2 border border-outline-variant text-on-surface-variant px-6 py-3 font-label-md text-label-md uppercase tracking-widest hover:border-primary hover:text-primary transition-all"
      >
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0">open_in_new</span>
        Ver perfil en Instagram
      </a>
    </div>

  </div>
</section>

<style>
  .scrollbar-none {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>
